# ─────────────────────────────────────────────────────────────────────────────
# ChefNet Invest — Environment Variables
# Copy this file to .env and fill in all values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001

# Public URL of the site (no trailing slash)
VITE_SITE_URL=https://chefnet.ai

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Any long random secret — used to bootstrap the first admin account
# Generate with: openssl rand -hex 32
ADMIN_BOOTSTRAP_SECRET=your_very_long_random_secret_here

# ── Sumsub KYC ────────────────────────────────────────────────────────────────
# Found in: https://developers.sumsub.com/
SUMSUB_APP_TOKEN=prd:YOUR_APP_TOKEN
SUMSUB_SECRET_KEY=YOUR_SECRET_KEY
SUMSUB_LEVEL_NAME=id-and-liveness

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used for sending verification, password reset, and notification emails.
# Example: Gmail with App Password, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=ChefNet Invest <your-email@gmail.com>

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# Used for signing session cookies (optional — app uses Supabase JWTs primarily)
SESSION_SECRET=your_very_long_session_secret_here

# Cookie signing secret (optional)
# Generate with: openssl rand -hex 32
COOKIE_SECRET=your_cookie_signing_secret_here
